{
  "displayName": "SLIs - cicdtraining",
  "gridLayout": {
    "columns": "2",
    "widgets": [
      {
        "title": "SLI #1 — Tasa de errores 5xx",
        "xyChart": {
          "dataSets": [{
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"run.googleapis.com/request_count\" resource.type=\"cloud_run_revision\" resource.label.service_name=\"mi-app\"",
                "aggregation": {
                  "alignmentPeriod": "60s",
                  "perSeriesAligner": "ALIGN_RATE",
                  "crossSeriesReducer": "REDUCE_SUM",
                  "groupByFields": ["metric.label.response_code_class"]
                }
              }
            },
            "plotType": "LINE"
          }],
          "timeshiftDuration": "0s",
          "yAxis": { "label": "Requests/seg", "scale": "LINEAR" }
        }
      },
      {
        "title": "SLI #2 — Latencia p95 (ms)",
        "xyChart": {
          "dataSets": [{
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"run.googleapis.com/request_latencies\" resource.type=\"cloud_run_revision\" resource.label.service_name=\"mi-app\"",
                "aggregation": {
                  "alignmentPeriod": "60s",
                  "perSeriesAligner": "ALIGN_DELTA",
                  "crossSeriesReducer": "REDUCE_PERCENTILE_95"
                }
              }
            },
            "plotType": "LINE"
          }],
          "yAxis": { "label": "Latencia ms", "scale": "LINEAR" }
        }
      },
      {
        "title": "SLI #3 — Disponibilidad (requests 2xx vs total)",
        "xyChart": {
          "dataSets": [{
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"run.googleapis.com/request_count\" resource.type=\"cloud_run_revision\" resource.label.service_name=\"mi-app\" metric.label.response_code_class=\"2xx\"",
                "aggregation": {
                  "alignmentPeriod": "60s",
                  "perSeriesAligner": "ALIGN_RATE",
                  "crossSeriesReducer": "REDUCE_SUM"
                }
              }
            },
            "plotType": "STACKED_AREA"
          }],
          "yAxis": { "label": "Requests 2xx/seg", "scale": "LINEAR" }
        }
      },
      {
        "title": "Concurrencia — Requests activos",
        "xyChart": {
          "dataSets": [{
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"run.googleapis.com/container/instance_count\" resource.type=\"cloud_run_revision\" resource.label.service_name=\"mi-app\"",
                "aggregation": {
                  "alignmentPeriod": "60s",
                  "perSeriesAligner": "ALIGN_MEAN",
                  "crossSeriesReducer": "REDUCE_SUM"
                }
              }
            },
            "plotType": "LINE"
          }],
          "yAxis": { "label": "Instancias", "scale": "LINEAR" }
        }
      }
    ]
  }
}